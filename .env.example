# Copy to .env for local development (optional).
# Docker Compose sets service URLs automatically; use this file for non-Docker runs.

# Streamlit → FastAPI (local)
CREDIT_RISK_API_URL=http://127.0.0.1:8000

# Docker Compose frontend uses: http://backend:8000

# Portfolio CSV path (local or container)
CREDIT_RISK_PORTFOLIO_CSV=data/application_train.csv
